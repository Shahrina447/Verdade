# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── uv ────────────────────────────────────────────────────────────────────────
# uv.lock should be committed (reproducible installs), but cache should not
.uv-cache/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migrations/versions/ — those should be committed
# But never commit a DB snapshot
*.sqlite
*.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

xlmroberta_urdu_best.pt 

data/
